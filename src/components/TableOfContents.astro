---
import TableOfContentsHeading from '@/components/TabletOfContentsHeading'

const { headings } = Astro.props

type TableOfContent = {
	depth: number
	text: string
	slug: string
	subheadings: TableOfContent[]
}

const toc = buildToc(headings)
function buildToc(headings: TableOfContent[]) {
	let toc: TableOfContent[] = []
	let parentHeadings = new Map()
	headings.forEach((h) => {
		let heading = { ...h, subheadings: [] }
		parentHeadings.set(heading.depth, heading)
		if (heading.depth === 1 || heading.depth === 2) {
			toc.push(heading)
		} else {
			parentHeadings.get(heading.depth - 1).subheadings.push(heading)
		}
	})
	return toc
}
---

<nav class='toc-panel' aria-label='Table of contents'>
	<header class='toc-panel__header'>
		<p class='toc-panel__eyebrow'>On this page</p>
		<h2 class='toc-panel__title'>Contents</h2>
	</header>

	<ul class='toc-panel__list'>
		{toc.map((heading) => <TableOfContentsHeading heading={heading} />)}
	</ul>
</nav>

<style>
	.toc-panel {
		overflow: hidden;
		border-radius: 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.96));
		box-shadow:
			0 1px 2px rgba(15, 23, 42, 0.06),
			0 10px 24px -18px rgba(15, 23, 42, 0.28);
	}

	:global(html.dark) .toc-panel {
		border-color: rgba(255, 255, 255, 0.08);
		background: linear-gradient(180deg, rgba(30, 30, 46, 0.96), rgba(20, 20, 32, 0.98));
		box-shadow:
			0 1px 2px rgba(0, 0, 0, 0.35),
			0 12px 28px -18px rgba(0, 0, 0, 0.65);
	}

	.toc-panel__header {
		padding: 1rem 1rem 0.85rem;
		border-bottom: 1px solid rgba(15, 23, 42, 0.08);
	}

	:global(html.dark) .toc-panel__header {
		border-bottom-color: rgba(255, 255, 255, 0.08);
	}

	.toc-panel__eyebrow {
		margin: 0;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgb(79 70 229);
	}

	:global(html.dark) .toc-panel__eyebrow {
		color: rgb(165 180 252);
	}

	.toc-panel__title {
		margin: 0.35rem 0 0;
		font-size: 1.1rem;
		font-weight: 700;
		line-height: 1.3;
		color: rgb(15 23 42);
	}

	:global(html.dark) .toc-panel__title {
		color: rgb(248 250 252);
	}

	.toc-panel__list {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		padding: 0.65rem;
	}
</style>
